        }
      }

      // Mark target question as Visited (NOT_ANSWERED) if it was NOT_VISITED
      const nextQ = examQuestions[targetIndex];
      if (nextQ && updated[nextQ.id] && updated[nextQ.id].palette_status === 'NOT_VISITED') {
