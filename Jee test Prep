                      }

                      return (
                        <div className="divide-y divide-slate-150 max-h-[500px] overflow-y-auto scrollbar-thin bg-white">
                          {filtered.map(q => {
                            let badgeClass = 'bg-blue-50 text-blue-700 border-blue-100';
                            if (q.subject === 'CHEMISTRY') badgeClass = 'bg-teal-50 text-teal-700 border-teal-100';
                            if (q.subject === 'MATHEMATICS') badgeClass = 'bg-fuchsia-50 text-fuchsia-700 border-fuchsia-100';

                            return (
                              <div key={q.id} className="grid grid-cols-12 gap-2 p-3 items-start text-xs hover:bg-slate-50 transition-colors">
                                <div className="col-span-1 font-mono font-bold text-slate-400 self-center">
                                  #{q.id}
                                </div>

                                <div className="col-span-3 space-y-1">
                                  <span className={`inline-block px-1.5 py-0.5 rounded border text-[8px] font-black uppercase ${badgeClass}`}>
                                    {q.subject}
                                  </span>
                                  <span className="block font-black text-[10px] text-slate-750 line-clamp-2" title={q.chapter}>
                                    {q.chapter}
                                  </span>
                                  <span className="block text-[8px] text-indigo-600 font-extrabold uppercase tracking-wide">
                                    {q.topic}
                                  </span>
                                  <span className="inline-block px-1 bg-slate-100 text-slate-500 rounded text-[8px] font-black">
                                    {q.question_type}
                                  </span>
                                </div>

                                <div className="col-span-6 space-y-2 pr-3">
                                  <div className="text-xxs text-slate-800 leading-normal bg-slate-50/50 p-2 rounded border border-slate-100 font-medium select-all">
                                    {q.question_text.length > 300 ? q.question_text.slice(0, 300) + '...' : q.question_text}
                                  </div>
                                  
                                  {q.options && (
                                    <div className="grid grid-cols-2 gap-x-2 gap-y-0.5 text-[9px] text-slate-500 pl-1 font-semibold">
                                      <div>A: <span className="text-slate-700">{q.options.A}</span></div>
                                      <div>B: <span className="text-slate-700">{q.options.B}</span></div>
                                      <div>C: <span className="text-slate-700">{q.options.C}</span></div>
                                      <div>D: <span className="text-slate-700">{q.options.D}</span></div>
                                    </div>
                                  )}
                                  
                                  <div className="flex gap-2">
                                    <span className="text-[9px] font-extrabold text-emerald-800 bg-emerald-50 border border-emerald-100 px-1.5 py-0.5 rounded">
                                      Correct Answer: {q.correct_answer}
                                    </span>
                                  </div>
                                </div>

                                <div className="col-span-2 flex justify-end gap-1.5 self-center">
                                  <button
                                    type="button"
                                    onClick={() => setAdminEditingQuestion(q)}
                                    className="p-1 px-2.5 bg-indigo-50 border border-indigo-150 text-indigo-700 rounded-lg hover:bg-indigo-100 transition-colors flex items-center gap-1 font-bold text-[9px] uppercase tracking-wider cursor-pointer"
                                  >
                                    <Edit className="w-3 h-3" /> Edit
                                  </button>
                                  <button
                                    type="button"
                                    onClick={() => handleDeleteQuestion(q.id)}
                                    className="p-1 px-2 bg-rose-50 border border-rose-150 text-rose-700 hover:bg-rose-100 rounded-lg transition-colors flex items-center gap-1 font-bold text-[9px] uppercase tracking-wider cursor-pointer"
                                  >
                                    <Trash2 className="w-3 h-3" /> Del
                                  </button>
                                </div>
                              </div>
                            );
                          })}
                        </div>
                      );
                    })()
                  )}
                </div>
              </div>

              {/* Creator-exclusive Student Database Records (Requested Tables) */}
              <div className="bg-white border border-slate-200 rounded-xl p-5 shadow-sm space-y-6">
                <div className="flex flex-col sm:flex-row sm:items-center justify-between border-b border-slate-50 pb-3 gap-2">
                  <div>
                    <h3 className="font-extrabold text-slate-800 flex items-center gap-2 text-sm uppercase tracking-wide">
                      <Layers className="text-indigo-600 w-4 h-4 animate-pulse" /> Student Registries & Performance Databases
                    </h3>
                    <p className="text-[10px] text-slate-400 mt-0.5">
                      Relational structures containing logs of student activities, PINs, and simulated JEE score outputs.
                    </p>
                  </div>
                  <div className="flex items-center gap-2 flex-wrap shrink-0">
                    <a
                      href="/api/admin/download-db"
                      download
                      className="bg-indigo-600 hover:bg-indigo-700 text-white text-[10px] font-black px-3 py-1.5 rounded-lg uppercase tracking-wider flex items-center gap-1.5 shadow-sm transition-colors cursor-pointer"
                    >
                      <Download className="w-3.5 h-3.5" /> Download db.json Backup
                    </a>
                    <span className="bg-amber-100 text-amber-800 border border-amber-200 text-[10px] font-black px-2.5 py-1 rounded-md uppercase tracking-wider shrink-0">
                      Admin Exclusive Console
                    </span>
                  </div>
                </div>

                {loadingAdminTables ? (
                  <div className="flex items-center justify-center py-8 space-y-2 flex-col">
                    <div className="w-6 h-6 border-2 border-indigo-600 border-t-transparent rounded-full animate-spin"></div>
                    <span className="text-[10px] font-bold text-slate-400">Loading Student Registries...</span>
                  </div>
                ) : (
                  <div className="space-y-6">
                    {/* T1: Registered Student Login Logs */}
                    <div className="space-y-2">
                      <h4 className="text-[11px] font-extrabold text-indigo-950 flex items-center justify-between uppercase tracking-wider bg-slate-50 p-2.5 rounded-lg border border-slate-150">
                        <span className="flex items-center gap-1.5"><User className="w-3.5 h-3.5 text-indigo-600" /> Database Table 1: Registered Candidates (Login log)</span>
                        <span className="text-[10px] bg-indigo-100 text-indigo-800 px-2 py-0.5 rounded-full font-mono lowercase">{adminUsers.length} entries</span>
                      </h4>
                      <div className="overflow-x-auto border border-slate-150 rounded-lg">
                        <table className="w-full text-slate-650 text-[11px] text-left border-collapse">
                          <thead className="bg-slate-100/80 font-extrabold text-slate-700 uppercase text-[9px] tracking-wider border-b border-slate-150">
                            <tr>
                              <th className="px-3 py-2">UID / Candidate ID</th>
                              <th className="px-3 py-2">Candidate Info</th>
                              <th className="px-3 py-2">DOB</th>
                              <th className="px-3 py-2">Bypass PIN</th>
                              <th className="px-3 py-2 text-center">Logins Count</th>
                              <th className="px-3 py-2 text-right">Avg Session Duration</th>
                            </tr>
                          </thead>
                          <tbody className="divide-y divide-slate-100">
                            {adminUsers.length === 0 ? (
                              <tr>
                                <td colSpan={6} className="text-center py-4 text-slate-400 font-medium">No students registered in the database yet.</td>
                              </tr>
                            ) : (
                              adminUsers.map(user => {
                                const avgSec = user.number_of_logins > 0 
                                  ? Math.round((user.total_login_duration_seconds || 0) / user.number_of_logins) 
                                  : 0;
                                const hrs = Math.floor(avgSec / 3600);
                                const mins = Math.floor((avgSec % 3600) / 60);
                                const secs = avgSec % 60;
                                const durationFormatted = hrs > 0 
                                  ? `${hrs}h ${mins}m` 
                                  : mins > 0 
                                    ? `${mins}m ${secs}s` 
                                    : `${secs}s`;

                                return (
                                  <tr key={user.id} className="hover:bg-slate-50/55 transition-colors">
                                    <td className="px-3 py-2 font-mono font-bold text-indigo-600 text-[10px] whitespace-nowrap">
                                      {user.candidate_id || `CAND-${user.id}`}
                                    </td>
                                    <td className="px-3 py-2 whitespace-nowrap">
                                      <span className="font-extrabold text-slate-800 block text-xs">{user.username}</span>
                                      <span className="text-[10px] text-slate-500 block">{user.email_id} • {user.mobile_number}</span>
                                    </td>
                                    <td className="px-3 py-2 font-semibold text-slate-750 whitespace-nowrap">{user.dob || '15-05-2006'}</td>
                                    <td className="px-3 py-2 whitespace-nowrap">
                                      <span className="font-mono bg-slate-100 px-1.5 py-0.5 rounded text-slate-600 font-bold">{user.password || '123456'}</span>
                                    </td>
                                    <td className="px-3 py-2 text-center font-bold text-slate-800">{user.number_of_logins || 1}</td>
                                    <td className="px-3 py-2 text-right font-semibold text-slate-700 font-mono whitespace-nowrap">{durationFormatted}</td>
                                  </tr>
                                );
                              })
                            )}
                          </tbody>
                        </table>
                      </div>
                    </div>

                    {/* T2: JEE Mock Candidate Performance Records */}
                    <div className="space-y-2">
                      <h4 className="text-[11px] font-extrabold text-indigo-950 flex items-center justify-between uppercase tracking-wider bg-slate-50 p-2.5 rounded-lg border border-slate-150">
                        <span className="flex items-center gap-1.5"><Award className="w-3.5 h-3.5 text-indigo-600" /> Database Table 2: Simulated Test Performance Records (Exam analytics)</span>
                        <span className="text-[10px] bg-indigo-100 text-indigo-800 px-2 py-0.5 rounded-full font-mono lowercase">{adminAttempts.length} entries</span>
                      </h4>
                      <div className="overflow-x-auto border border-slate-150 rounded-lg">
                        <table className="w-full text-slate-650 text-[11px] text-left border-collapse">
                          <thead className="bg-slate-100/80 font-extrabold text-slate-700 uppercase text-[9px] tracking-wider border-b border-slate-150">
                            <tr>
                              <th className="px-3 py-2">Test ID</th>
                              <th className="px-3 py-2">Candidate Info</th>
                              <th className="px-3 py-2">Date & Time</th>
                              <th className="px-3 py-2">Syllabus Coverage</th>
                              <th className="px-3 py-2 text-center">Score achieved</th>
                              <th className="px-3 py-2 text-right">Extrapolated Percentile</th>
                            </tr>
                          </thead>
                          <tbody className="divide-y divide-slate-100">
                            {adminAttempts.length === 0 ? (
                              <tr>
                                <td colSpan={6} className="text-center py-4 text-slate-400 font-medium">No test results submitted by candidates yet.</td>
                              </tr>
                            ) : (
                              [...adminAttempts].reverse().map(att => {
                                const chapsLabel = att.syllabus_chapters?.length > 0 
                                  ? `${att.syllabus_chapters.length} chapters selected` 
                                  : 'All Syllabus';
                                
                                return (
                                  <tr key={att.id} className="hover:bg-slate-50/55 transition-colors">
                                    <td className="px-3 py-2 font-mono font-bold text-slate-400 text-[10px] whitespace-nowrap">#T-00{att.id}</td>
                                    <td className="px-3 py-2 whitespace-nowrap">
                                      <span className="font-extrabold text-slate-800 block text-xs">{att.candidate_name}</span>
                                      <span className="text-[9px] text-indigo-650 font-extrabold font-mono uppercase tracking-wider">{att.candidate_id}</span>
                                    </td>
                                    <td className="px-3 py-2 whitespace-nowrap font-medium text-slate-500">
                                      {new Date(att.attempted_at).toLocaleDateString()} {new Date(att.attempted_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
                                    </td>
                                    <td className="px-3 py-2 max-w-[200px] truncate" title={att.syllabus_chapters?.join(', ')}>
                                      <span className="font-semibold text-slate-700">{chapsLabel}</span>
                                    </td>
                                    <td className="px-3 py-2 text-center whitespace-nowrap">
                                      <span className="bg-indigo-50 text-indigo-800 border border-indigo-200 rounded px-2 py-0.5 font-bold font-mono">
                                        {att.total_score} marks
                                      </span>
                                    </td>
                                    <td className="px-3 py-2 text-right whitespace-nowrap font-bold text-[10px] font-mono">
                                      <div className="font-semibold text-emerald-850">Jan: {formatPercentileRange(att.percentile_jan).replace(' %ile', '')}</div>
                                      <div className="font-semibold text-teal-850">Apr: {formatPercentileRange(att.percentile_april).replace(' %ile', '')}</div>
                                    </td>
                                  </tr>
                                );
                              })
                            )}
                          </tbody>
                        </table>
                      </div>
                    </div>
                  </div>
                )}
              </div>

              {/* Reset Database Cleanly Banner at the Bottom */}
              <div className="space-y-3">
                {wipeStatusMessage && (
                  <div className={`p-4 rounded-xl border text-xs font-semibold animate-pulse shadow-sm ${
                    wipeStatusMessage.startsWith('success:') 
                      ? 'bg-emerald-50 border-emerald-200 text-emerald-900' 
                      : 'bg-rose-50 border-rose-200 text-rose-900'
                  }`}>
                    {wipeStatusMessage.replace(/^(success|error):\s*/, '')}
                  </div>
                )}

                <div className={`border rounded-xl p-5 flex flex-col gap-4 transition-all duration-300 ${
                  wipeState === 'idle' 
                    ? 'bg-rose-50/70 border-rose-200' 
                    : wipeState === 'warning1' 
                      ? 'bg-amber-50 border-amber-300 shadow-md ring-1 ring-amber-400' 
                      : 'bg-rose-950/95 border-rose-600 shadow-xl text-white ring-2 ring-rose-500 animate-pulse'
                }`}>
                  {wipeState === 'idle' && (
                    <div className="flex flex-col md:flex-row justify-between items-start md:items-center gap-3">
                      <div className="space-y-1">
                        <h5 className="font-extrabold text-xs text-rose-950 flex items-center gap-1.5 uppercase tracking-wide">
                          <Trash2 className="w-4 h-4 text-rose-650" /> Database Reset & Preparation Zone
                        </h5>
                        <p className="text-xxs leading-normal max-w-xl text-rose-750">
                          To restart the parsing lifecycle completely clear of any previous tagging or doubled questions, click the button to wipe the library. This will instantly reset all syllabus topic/subcategory active question counts to 0.
                        </p>
                      </div>
                      <button
                        onClick={() => {
                          setWipeState('warning1');
                          setWipeStatusMessage(null);
                        }}
                        type="button"
                        className="shrink-0 bg-rose-600 hover:bg-rose-700 text-white font-black px-4 py-2.5 rounded-lg text-xxs uppercase tracking-wider transition-colors shadow-sm cursor-pointer"
                      >
                        Wipe Database Options
                      </button>
                    </div>
                  )}

                  {wipeState === 'warning1' && (
                    <div className="space-y-4">
                      <div className="space-y-1">
                        <h5 className="font-extrabold text-xs text-amber-950 flex items-center gap-1.5 uppercase tracking-wide">
                          <AlertTriangle className="w-4 h-4 text-amber-600 animate-bounce" /> Database Modification: Choice of Action
                        </h5>
                        <p className="text-xxs leading-normal text-amber-900 font-semibold">
                          Please select how you would like to proceed with the database reset. You can either cleanly remove only your most recent upload session or wipe out all questions completely.
                        </p>
                      </div>

                      <div className="grid grid-cols-1 md:grid-cols-2 gap-3 pt-1">
                        {/* Option 1 */}
                        <div className="border border-amber-250 bg-white/70 p-3 rounded-lg flex flex-col justify-between items-start gap-2.5">
                          <div>
                            <span className="bg-amber-100 text-amber-800 text-[9px] font-black uppercase px-2 py-0.5 rounded tracking-wider border border-amber-200">
                              Option 1
                            </span>
                            <h6 className="font-extrabold text-xs text-slate-800 mt-1.5 uppercase tracking-wide">Delete Last Upload Only</h6>
                            <p className="text-[10px] text-slate-500 mt-0.5 leading-relaxed">
                              Safely deletes only those questions that were uploaded can parsed in your very last PDF parser run, preserving all previous batches.
                            </p>
                          </div>
                          <button
                            onClick={() => handleClearQuestions('last_batch')}
                            type="button"
                            className="bg-amber-600 hover:bg-amber-700 text-white font-extrabold text-[10px] uppercase tracking-wider px-3 py-1.5 rounded transition-colors self-end"
                          >
                            Execute Option 1
                          </button>
                        </div>

                        {/* Option 2 */}
                        <div className="border border-rose-200 bg-rose-50/40 p-3 rounded-lg flex flex-col justify-between items-start gap-2.5">
                          <div>
                            <span className="bg-rose-100 text-rose-800 text-[9px] font-black uppercase px-2 py-0.5 rounded tracking-wider border border-rose-200">
                              Option 2
                            </span>
                            <h6 className="font-extrabold text-xs text-rose-950 mt-1.5 uppercase tracking-wide">Delete Everything (Entire DB)</h6>
                            <p className="text-[10px] text-slate-600 mt-0.5 leading-relaxed font-medium">
                              Clears the entire active questions repository and resets category counters back to zero. This will require another confirmation warning step.
                            </p>
                          </div>
                          <button
                            onClick={() => setWipeState('confirm_all')}
                            type="button"
                            className="bg-rose-605 bg-rose-600 hover:bg-rose-750 text-white font-extrabold text-[10px] uppercase tracking-wider px-3 py-1.5 rounded transition-colors self-end"
                          >
                            Review Option 2
                          </button>
                        </div>
                      </div>

                      <div className="flex justify-end pt-2 border-t border-amber-200/50">
                        <button
                          onClick={() => setWipeState('idle')}
                          type="button"
                          className="bg-slate-700 hover:bg-slate-650 text-white font-bold px-3 py-1.5 rounded text-xxs uppercase tracking-wider transition-colors cursor-pointer"
                        >
                          Cancel / Back
                        </button>
                      </div>
                    </div>
                  )}

                  {wipeState === 'confirm_all' && (
                    <div className="space-y-4">
                      <div className="space-y-2">
                        <h5 className="font-extrabold text-xs text-rose-200 flex items-center gap-1.5 uppercase tracking-widest text-shadow">
                          <Trash2 className="w-5 h-5 text-rose-450 animate-bounce" /> CRITICAL SYSTEM OVERWRITE CONFIRMATION (STEP 2 OF 2)
                        </h5>
                        <p className="text-xxs leading-relaxed font-bold text-rose-100 bg-rose-950 border border-rose-800 p-3 rounded-lg">
                          DANGER: Are you absolutely certain you want to wipe ALL questions from the relational database? This action is immediate, irreversible, and CANNOT be undone. All active syllabus taxonomy counts and performance records will instantly reset to 0.
                        </p>
                      </div>

                      <div className="flex flex-wrap gap-2.5 justify-end pt-2 border-t border-rose-800/50">
                        <button
                          onClick={() => setWipeState('warning1')}
                          type="button"
                          className="bg-slate-800 hover:bg-slate-700 border border-slate-700 text-rose-200 font-extrabold px-3 py-2 rounded text-xxs uppercase tracking-wider transition-colors cursor-pointer"
                        >
                          Cancel / Back
                        </button>
                        <button
                          onClick={() => handleClearQuestions('all')}
                          type="button"
                          className="bg-rose-600 hover:bg-rose-500 text-white font-black px-4 py-2 rounded text-xxs uppercase tracking-widest transition-colors shadow-lg cursor-pointer animate-pulse border border-rose-400"
                        >
                          Wipe Database Cleanly
                        </button>
                      </div>
                    </div>
                  )}
                </div>
              </div>

            </motion.div>
          )}
        </AnimatePresence>
      </main>
    </div>
  );
}
