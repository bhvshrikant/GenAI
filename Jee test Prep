      if (val === 'CLEAR') {
        updated[activeQ.id].selected_answer = '';
      } else if (val === 'BACKSPACE') {
        updated[activeQ.id].selected_answer = currentVal.slice(0, -1);
      } else if (val === '-') {
        // Negation toggle
        if (currentVal.startsWith('-')) {
          updated[activeQ.id].selected_answer = currentVal.slice(1);
        } else {
          updated[activeQ.id].selected_answer = '-' + currentVal;
        }
      } else if (val === '.') {
        if (!currentVal.includes('.')) {
          updated[activeQ.id].selected_answer = currentVal + '.';
        }
      } else {
        // Max standard length constraint
        if (currentVal.length < 8) {
          updated[activeQ.id].selected_answer = currentVal + val;
