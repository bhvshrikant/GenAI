            fetchTaxonomy();
            fetchAdminQuestions();
            fetchAdminLogs();
          } else {
            triggerStatus('error', 'Restore Handshake Failed', 'The local server database rejected the backup payload.');
          }
        } else {
          triggerStatus('error', 'Invalid Schema', 'The downloaded cloud backup file does not match database layout.');
        }
      } else {
        const errBody = await downloadRes.text();
        throw new Error(errBody || "Failed to download backup file.");
      }
    } catch (err: any) {
